{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "defaultMode": "plan",
  "disableBypassPermissionsMode": true,
  "useAutoModeDuringPlan": false,
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(tree *)",
      "Bash(cargo check *)",
      "Bash(cargo test *)",
      "Bash(cargo clippy *)",
      "Bash(npm run test *)",
      "Bash(npm run lint *)",
      "Bash(pnpm test *)",
      "Bash(pnpm lint *)",
      "Bash(node *)"
    ],
    "ask": [
      "Edit",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(npm install *)",
      "Bash(pnpm install *)",
      "Bash(cargo add *)",
      "Bash(cargo install *)",
      "Bash(rustup *)",
      "WebFetch"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./*.pem)",
      "Read(./*.key)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(./secrets/**)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "excludedCommands": [
      "docker *"
    ],
    "network": {
      "allowedDomains": [
        "github.com",
        "*.githubusercontent.com",
        "registry.npmjs.org",
        "crates.io",
        "docs.rs",
        "pypi.org",
        "files.pythonhosted.org"
      ]
    }
  }
}
